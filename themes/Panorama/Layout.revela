<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ gallery.description ?? site.description }}">
  <title>{{~ if gallery.title ~}}{{ gallery.title }} – {{ site.title }}{{~ else ~}}{{ site.title }}{{~ end ~}}</title>
  <meta property="og:title" content="{{ gallery.title ?? site.title }}">
  <meta property="og:description" content="{{ gallery.description ?? site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="de_DE">
  {{~ include 'favicon' ~}}
  {{~ og_logo = find_image "logo.jpg" ~}}
  {{~ if og_logo ~}}
  <meta property="og:image" content="{{ image_basepath }}{{ og_logo.url }}/1280.jpg">
  {{~ end ~}}
  {{~ for css in stylesheets ~}}
  <link rel="stylesheet" href="{{ basepath }}_assets/{{ css }}">
  {{~ end ~}}
</head>
<body>

  {{~ logo = find_image "logo.jpg" ~}}
  <div class="site-banner">
    <a href="{{ basepath == '' ? '.' : basepath }}">
      {{~ if logo ~}}
      <picture>
        {{~ for format in image_formats ~}}
        <source type="image/{{ format }}" srcset="
          {{~ for size in logo.sizes ~}}
          {{- image_basepath }}{{ logo.url }}/{{ size }}.{{ format }} {{ size }}w{{ if !for.last }},{{ end }}
          {{~ end ~}}">
        {{~ end ~}}
        <img src="{{ image_basepath }}{{ logo.url }}/{{ logo.sizes[logo.sizes.size - 1] }}.jpg"
             alt="Alpenstrasse 8 – Die Ferienwohnung mit Panoramaausblick" class="site-logo"
             width="{{ logo.width }}" height="{{ logo.height }}" loading="eager">
      </picture>
      {{~ else ~}}
      <img src="{{ basepath }}images/logo.jpg" alt="Alpenstrasse 8 – Die Ferienwohnung mit Panoramaausblick" class="site-logo" width="600" height="120">
      {{~ end ~}}
    </a>
  </div>

  <header class="site-header">
    <div class="header-inner">
      <nav>
        <ul class="main-nav">
          {{~ for item in nav_items ~}}
          {{~ if !item.hidden ~}}
          <li><a href="{{ basepath }}{{ item.url }}"{{ if item.active }} class="active"{{ end }}>{{ item.text }}</a></li>
          {{~ end ~}}
          {{~ end ~}}
        </ul>
      </nav>
    </div>
  </header>

  {{~ if gallery.cover_image ~}}
  <section class="hero-panorama">
    <picture>
      {{~ for format in image_formats ~}}
      <source type="image/{{ format }}" srcset="
        {{~ for size in gallery.cover_image.sizes ~}}
        {{- image_basepath }}{{ gallery.cover_image.url }}/{{ size }}.{{ format }} {{ size }}w{{ if !for.last }},{{ end }}
        {{~ end ~}}" sizes="100vw">
      {{~ end ~}}
      <img src="{{ image_basepath }}{{ gallery.cover_image.url }}/{{ gallery.cover_image.sizes[gallery.cover_image.sizes.size - 1] }}.jpg"
           alt="{{ gallery.title }}"
           width="{{ gallery.cover_image.width }}" height="{{ gallery.cover_image.height }}"
           loading="eager" decoding="async">
    </picture>
  </section>
  {{~ end ~}}

  <main>
    {{~ body_template = 'body/' + (gallery.template ?? 'page') ~}}
    {{~ include body_template ~}}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <span>&copy; {{ date.now | date.to_string "%Y" }} {{ site.copyright }}</span>
      <a href="{{ basepath }}impressum/">Impressum</a>
    </div>
  </footer>

</body>
</html>
